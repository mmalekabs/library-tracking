# Copy to .env and replace placeholders — never commit .env to git.
#
# ─── LOCAL DEVELOPMENT (your PC) ─────────────────────────
# Use the PUBLIC connection string from Railway Postgres:
#   Service → Connect → "Public Network" / TCP proxy URL
# Host looks like:  *.proxy.rlwy.net  (NOT postgres.railway.internal)
DATABASE_URL="postgresql://USER:PASSWORD@HOST.proxy.rlwy.net:PORT/railway"

# ─── RAILWAY DEPLOYED SERVER ─────────────────────────────
# In the Railway backend service Variables, set (via dashboard, not in code):
#   DATABASE_URL = ${{Postgres.DATABASE_URL}}
#   ADMIN_USERNAME = ...
#   ADMIN_PASSWORD = ...
#   JWT_SECRET = ...
#   CLIENT_URL = https://your-frontend-url

# Admin login (web app only — not the Postgres password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-use-a-strong-password

# Sign JWTs — use a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string

NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
