generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────

enum BookFormat {
  PHYSICAL
  DIGITAL
  AUDIO
}

enum BindingType {
  PAPERBACK
  HARDCOVER
  MASS_MARKET_PAPERBACK
  KINDLE_EDITION
  UNKNOWN
}

// ─── MODELS ───────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Author {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booksAsPrimary    Book[]                 @relation("PrimaryAuthor")
  booksAsAdditional BookAdditionalAuthor[]
}

model Publisher {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  books Book[]
}

model Book {
  id         String  @id @default(cuid())
  externalId String? @unique
  title      String
  isbn       String?
  isbn13     String?

  purchasePrice Decimal? @db.Decimal(10, 2)
  marketPrice   Decimal? @db.Decimal(10, 2)
  currency      String   @default("SAR")

  format                  BookFormat  @default(PHYSICAL)
  binding                 BindingType @default(PAPERBACK)
  numberOfPages           Int?
  yearPublished           Int?
  originalPublicationYear Int?
  edition                 String?

  isPubliclyVisible Boolean @default(true)
  isGift            Boolean @default(false)
  toPurchase        Boolean @default(false)
  toSell            Boolean @default(false)
  coverImageUrl     String?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String?
  author   Author? @relation("PrimaryAuthor", fields: [authorId], references: [id])

  additionalAuthors BookAdditionalAuthor[]
  publisherId       String?
  publisher         Publisher?             @relation(fields: [publisherId], references: [id])

  @@index([title])
  @@index([format])
  @@index([isPubliclyVisible])
  @@index([toPurchase])
  @@index([toSell])
  @@index([authorId])
  @@index([publisherId])
}

model BookAdditionalAuthor {
  bookId   String
  authorId String
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([bookId, authorId])
}
